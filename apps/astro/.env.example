# Astro Marketing Site Environment Variables
# Copy this file to .env and fill in your values

# Client-side (Public) - These are exposed to the browser
# URL of the React app (where users are redirected for login/dashboard)
PUBLIC_APP_URL=http://localhost:5173

# Optional: API URL if different from app
# PUBLIC_API_URL=http://localhost:3000

# Site URL for SEO/canonical links
PUBLIC_SITE_URL=https://filosign.io

# Server-side (Private) - These are NOT exposed to the browser
# Same values as public, but used during SSR/build
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
SERVER_URL=http://localhost:3000
