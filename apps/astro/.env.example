# Copy to `.env` in this folder (`apps/astro/.env`).

# Canonical origin — meta tags, OG URLs, astro.config `site` / sitemap (use real prod URL in CI)
PUBLIC_SITE_URL=https://filosign.xyz

# React / client app — CTAs ("Sign in", "Get Started"), redirects off the marketing site
PUBLIC_APP_URL=http://localhost:3000

# Your API / backend — health checks, server-only integrations, fetch from islands if needed
PUBLIC_SERVER_URL=http://localhost:30011
