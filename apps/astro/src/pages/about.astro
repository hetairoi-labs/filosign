---
import Footer from "../components/Footer.astro";
import AboutHeroIsland from "../components/islands/AboutHeroIsland";
import QuoteSectionIsland from "../components/islands/QuoteSectionIsland";
import ValuesSectionIsland from "../components/islands/ValuesSectionIsland";
import Navbar from "../components/Navbar.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
	title="About Filosign — Transforming document signing"
	description="Filosign is on a mission to transform document signing with secure, decentralized, and efficient solutions for the modern web."
>
	<div class="min-h-screen bg-background font-manrope selection:bg-primary/10 selection:text-primary">
		<Navbar />
		<main>
			<AboutHeroIsland client:load />
			<QuoteSectionIsland client:visible />
			<ValuesSectionIsland client:visible />
		</main>
		<Footer />
	</div>
</BaseLayout>
