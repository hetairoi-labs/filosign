---
import Footer from "../../components/Footer.astro";
import BlogPostIsland from "../../components/islands/BlogPostIsland";
import Navbar from "../../components/Navbar.astro";
import { getBlogPost } from "../../content/blog";
import BaseLayout from "../../layouts/BaseLayout.astro";

const post = getBlogPost("introduction");

const description =
	"Six months ago, we started working on Filosign; an idea focused on creating a completely private and end-to-end encrypted document signing standard.";
---

<BaseLayout
	title={`${post.title} — Filosign Blog`}
	description={description}
	canonicalUrl="https://filosign.io/blog/introduction/"
	image={post.heroImage}
>
	<div class="min-h-screen bg-background font-manrope selection:bg-primary/10 selection:text-primary">
		<Navbar />
		<main>
			<BlogPostIsland client:load post={post} />
		</main>
		<Footer />
	</div>
</BaseLayout>
