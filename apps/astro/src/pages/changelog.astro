---
import Footer from "../components/Footer.astro";
import ChangelogHeroIsland from "../components/islands/ChangelogHeroIsland";
import ChangelogListIsland from "../components/islands/ChangelogListIsland";
import Navbar from "../components/Navbar.astro";
import { ChangelogEntries } from "../content/changelog";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
	title="Changelog — What's new at Filosign"
	description="A changelog of new features, design improvements and enhancements lately. Stay up to date with the latest changes to Filosign."
>
	<div class="min-h-screen bg-background font-manrope selection:bg-primary/10 selection:text-primary">
		<Navbar />
		<main>
			<ChangelogHeroIsland client:load />
			<ChangelogListIsland client:visible entries={ChangelogEntries} />
		</main>
		<Footer />
	</div>
</BaseLayout>
