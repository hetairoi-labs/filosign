---
import { env } from "../env";

const appUrl = env.PUBLIC_APP_URL;
---

<section class="lg:max-w-[80dvw] mx-auto flex flex-col gap-6 md:gap-8 py-12 p-8 md:p-page">
	{/* Text Content Group - CSS animations for initial load */}
	<div class="flex flex-col gap-4" style="animation: fadeInUp 0.8s ease-out;">
		{/* Announcement Banner */}
		<div class="self-start group" style="animation: fadeInUp 1.3s ease-out;">
			<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-secondary/50 border border-secondary text-sm font-medium">
				<span class="relative flex h-2 w-2">
					<span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
					<span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
				</span>
				Public Beta
			</div>
		</div>

		{/* Main Headline */}
		<h1
			class="text-3xl sm:text-4xl md:text-5xl xl:text-7xl leading-tight"
			style="animation: fadeInUp 1.4s ease-out;"
		>
			Trustless standard for permanent agreements.
		</h1>

		{/* Sub-headline */}
		<p
			class="text-base sm:text-lg md:text-xl text-muted-foreground leading-relaxed -mt-2 font-manrope font-light"
			style="animation: fadeInUp 1.5s ease-out;"
		>
			Send, sign, and verify sensitive documents with encrypted workflows.
		</p>

		{/* Action Buttons */}
		<div
			class="flex flex-col sm:flex-row items-stretch sm:items-center gap-2"
			style="animation: fadeInUp 1.6s ease-out;"
		>
			<a
			href={appUrl}
			class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-primary text-primary-foreground rounded-md font-medium transition-all duration-200 hover:bg-primary/90 hover:scale-105 w-full sm:w-auto group"
			>
				Get Started
				<svg
					class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-1"
					viewBox="0 0 256 256"
					fill="currentColor"
				>
					<path d="m181.66 133.66-80 80A8 8 0 0 1 88 208V48a8 8 0 0 1 13.66-5.66l80 80a8 8 0 0 1 0 11.32Z"/>
				</svg>
			</a>

			<a
				href="https://github.com/hetairoi-labs/filosign"
				target="_blank"
				rel="noreferrer"
				class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-transparent text-foreground rounded-md font-medium transition-all duration-200 hover:bg-muted w-full sm:w-auto group"
			>
				<svg class="size-4" viewBox="0 0 256 256" fill="currentColor">
					<path d="M208 80v144a16 16 0 0 1-16 16h-48v-64h32v-16a24 24 0 0 0-24-24h-24v-64h32a40 40 0 0 1 48 8Zm-80 0v64h-24a24 24 0 0 0-24 24v16h32v64H64a16 16 0 0 1-16-16V80a40 40 0 0 1 48-8h32v64Zm-8-72a56 56 0 1 0-56 56 56 56 0 0 0 56-56Z"/>
				</svg>
				Source code
			</a>
		</div>
	</div>

	{/* Hero Video */}
	<div
		class="relative flex items-center justify-center rounded-3xl mt-4 overflow-hidden group"
		style="animation: fadeInUp 1.5s ease-out 0.2s both;"
	>
		<video
			autoplay
			loop
			muted
			playsinline
			width={1200}
			height={600}
			class="w-full h-auto aspect-video rounded-large relative z-10 shadow-sm object-cover"
			poster="/demo-poster.webp"
		>
			<source src="/demo.webm" type="video/webm" />
		</video>
	</div>
</section>

<style>
	@keyframes fadeInUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>
