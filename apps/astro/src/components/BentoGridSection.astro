---
interface BentoCardProps {
	imageSrc: string;
	imageAlt: string;
	badgeIcon: string;
	badgeText: string;
	badgeBgColor: string;
	stat: string;
	isInfinity?: boolean;
	subtitle: string;
	title: string;
	description: string;
}

const cards: BentoCardProps[] = [
	{
		imageSrc: "/images/stock_1.webp",
		imageAlt: "Legal Compliance",
		badgeIcon: "globe",
		badgeText: "Global",
		badgeBgColor: "bg-primary-light",
		stat: "180+",
		isInfinity: false,
		subtitle: "Countries Accepted",
		title: "Legally Binding",
		description:
			"Compliant with eIDAS, ESIGN, and UETA standards. Your signatures hold up in court anywhere.",
	},
	{
		imageSrc: "/images/stock_3.webp",
		imageAlt: "Perpetual Storage",
		badgeIcon: "harddrive",
		badgeText: "Perpetual",
		badgeBgColor: "bg-primary-light",
		stat: "∞",
		isInfinity: true,
		subtitle: "Storage Forever",
		title: "Irrevocable Access",
		description:
			"Documents are stored on the decentralized Filecoin network, ensuring they outlive any centralized server.",
	},
	{
		imageSrc: "/images/stock_5.webp",
		imageAlt: "Accelerated Workflow",
		badgeIcon: "lightning",
		badgeText: "Velocity",
		badgeBgColor: "bg-secondary-medium",
		stat: "5x",
		isInfinity: false,
		subtitle: "Faster Closing",
		title: "Programmable Settlement",
		description:
			"Attach payments directly to signatures. Signers automatically receive payment the moment they sign.",
	},
];
---

<section class="py-24 px-8 md:px-page max-w-7xl mx-auto">
	<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
		{cards.map((card, index) => (
			<div class="md:col-span-1 group" data-aos="fade-up" data-aos-delay={index * 100}>
				<div class="relative h-[400px] md:h-[500px] rounded-3xl overflow-hidden mb-6">
					<img
						src={card.imageSrc}
						alt={card.imageAlt}
						width={400}
						height={500}
						class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
					/>

					<div class="absolute inset-0 bg-black/30 p-8 flex flex-col justify-center items-center text-center">
						<div class="bg-white/90 backdrop-blur-sm pl-4 pr-6 py-2 rounded-full flex items-center gap-1 mb-4 shadow-sm">
							<div class:list={[card.badgeBgColor, "rounded-full p-1"]}>
								{card.badgeIcon === "globe" && (
									<svg class="size-5 text-black" viewBox="0 0 256 256" fill="currentColor">
										<path d="M128 24a104 104 0 1 0 104 104A104.11 104.11 0 0 0 128 24Zm0 192a88 88 0 1 1 0-176 88 88 0 0 1 0 176Zm-44-88a44 44 0 0 1 68.6-36.6 8 8 0 0 1-8.8 13.2 28 28 0 0 0-39.6 39.6 8 8 0 0 1-11.2 11.2A43.9 43.9 0 0 1 84 128Z"/>
									</svg>
									)}
								{card.badgeIcon === "harddrive" && (
									<svg class="size-5 text-black" viewBox="0 0 256 256" fill="currentColor">
										<path d="M240 136v64a16 16 0 0 1-16 16H32a16 16 0 0 1-16-16v-64a16 16 0 0 1 16-16h192a16 16 0 0 1 16 16Zm-16 64v-64H32v64h192Zm-72-32a12 12 0 1 0 12 12 12 12 0 0 0-12-12ZM72 120V56a40 40 0 0 1 80 0v8h16v-8a56 56 0 0 0-112 0v64a8 8 0 0 0 16 0Z"/>
									</svg>
									)}
								{card.badgeIcon === "lightning" && (
									<svg class="size-4 text-black" viewBox="0 0 256 256" fill="currentColor">
										<path d="M213.3 108a8 8 0 0 0-6.57-5.37l-52.64-7.68-23.52-47.68a8 8 0 0 0-14.34 0L92.91 94.95l-52.64 7.68A8 8 0 0 0 36.1 116l38.09 37.12-9 52.44a8 8 0 0 0 11.62 8.44L128 189.14l46.82 24.64a8 8 0 0 0 11.62-8.44l-9-52.44 38.09-37.12a8 8 0 0 0 2.17-8.18Z"/>
									</svg>
									)}
							</div>
							<span class="text-md font-manrope text-black">{card.badgeText}</span>
						</div>

						<div class="flex flex-col items-center justify-center">
							<div class="text-5xl mt-4 text-white drop-shadow-lg">
								{card.isInfinity ? (
									<svg class="size-16 -my-2 text-white" viewBox="0 0 256 256" fill="currentColor">
										<path d="M240 128a56 56 0 0 1-95.6 39.6l-33.4-36.7-33.4 36.7a56 56 0 1 1-17.2-16.4l26.1-28.7-26.1-28.7a56 56 0 1 1 17.2-16.4l33.4 36.7 33.4-36.7a56 56 0 1 1 17.2 16.4l-26.1 28.7 26.1 28.7A56 56 0 0 1 240 128Z"/>
									</svg>
								) : (
									card.stat
								)}
							</div>
							<div class="text-white/90 font-manrope text-sm mt-2">{card.subtitle}</div>
						</div>
					</div>
				</div>

				<div class="space-y-2 px-2" data-aos="fade-up" data-aos-delay={index * 100 + 50}>
					<h3 class="text-xl font-manrope">{card.title}</h3>
					<p class="text-muted-foreground text-sm leading-relaxed font-manrope font-light">
						{card.description}
					</p>
				</div>
			</div>
		))}
	</div>
</section>
