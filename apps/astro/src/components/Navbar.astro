---
import Logo from "./Logo.astro";
import { env } from "../env";

const navLinks = [
	{ label: "About", href: "/about" },
	{ label: "Blog", href: "/blog/introduction" },
	{ label: "Changelog", href: "/changelog" },
];

// App URL from env - buttons redirect here
const appUrl = env.PUBLIC_APP_URL;
---

<script>
	// Simple scroll hide behavior for navbar
	let lastScrollY = 0;
	let isVisible = true;

	const nav = document.querySelector('[data-nav]') as HTMLElement;

	function handleScroll() {
		const currentScrollY = window.scrollY;

		if (currentScrollY < 10) {
			isVisible = true;
		} else {
			isVisible = currentScrollY < lastScrollY;
		}

		lastScrollY = currentScrollY;

		if (nav) {
			if (isVisible) {
				nav.style.transform = 'translateY(0)';
				nav.style.opacity = '1';
			} else {
				nav.style.transform = 'translateY(-200px)';
				nav.style.opacity = '0';
			}
		}
	}

	window.addEventListener('scroll', handleScroll, { passive: true });
	// Initial state
	handleScroll();
</script>

<section class="sticky top-10 z-50 p-page">
	<nav
		data-nav
		class="flex justify-between items-center mx-auto max-w-3xl p-rect rounded-large glass text-background bg-foreground/90 transition-all duration-500"
		style="transform: translateY(0); opacity: 1;"
	>
		<!-- Logo -->
		<div class="flex items-center gap-4">
			<Logo textDelay={0.35} iconDelay={0.26} className="px-0 hidden md:block" redirectTo="/" iconOnly />
			<Logo textDelay={0.35} iconDelay={0.26} className="px-0" redirectTo="/" textOnly />
		</div>

		<!-- Desktop Navigation Links -->
		<div class="hidden items-center space-x-4 md:flex">
			{navLinks.map((link) => (
				<a
					href={link.href}
					class="font-medium transition-colors duration-200 hover:bg-foreground/50 rounded-md px-2 py-2"
				>
					{link.label}
				</a>
			))}
		</div>

		<!-- Desktop CTA Button - Redirects to React App -->
		<a
			href={appUrl}
			class="hidden md:flex items-center gap-2 px-4 py-2 bg-secondary text-primary-foreground rounded-md font-medium transition-all duration-200 hover:bg-secondary/90 hover:scale-105"
		>
			<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
				<polyline points="10,17 15,12 10,7"/>
				<line x1="15" y1="12" x2="3" y2="12"/>
			</svg>
			Connect
		</a>

		<!-- Mobile Menu Button -->
		<button
			id="mobile-menu-btn"
			class="md:hidden p-2 rounded-md hover:bg-foreground/50 transition-colors"
			aria-label="Toggle menu"
		>
			<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<line x1="3" y1="12" x2="21" y2="12"/>
				<line x1="3" y1="6" x2="21" y2="6"/>
				<line x1="3" y1="18" x2="21" y2="18"/>
			</svg>
		</button>
	</nav>

	<!-- Mobile Menu -->
	<div id="mobile-menu" class="hidden md:hidden fixed inset-x-0 top-24 z-40 px-4">
		<div class="bg-foreground/95 backdrop-blur-sm rounded-large p-4 shadow-lg">
			<div class="flex flex-col gap-2">
				{navLinks.map((link) => (
					<a
						href={link.href}
						class="font-medium transition-colors duration-200 hover:bg-foreground/50 rounded-md px-4 py-3 text-background"
					>
						{link.label}
					</a>
				))}
			<a
				href={appUrl}
				class="flex items-center justify-center gap-2 px-4 py-3 bg-secondary text-primary-foreground rounded-md font-medium mt-2"
			>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
						<polyline points="10,17 15,12 10,7"/>
						<line x1="15" y1="12" x2="3" y2="12"/>
					</svg>
					Connect
				</a>
			</div>
		</div>
	</div>
</section>

<script>
	// Mobile menu toggle
	const mobileMenuBtn = document.getElementById('mobile-menu-btn');
	const mobileMenu = document.getElementById('mobile-menu');

	if (mobileMenuBtn && mobileMenu) {
		mobileMenuBtn.addEventListener('click', () => {
			mobileMenu.classList.toggle('hidden');
		});

		// Close mobile menu when clicking a link
		mobileMenu.querySelectorAll('a').forEach(link => {
			link.addEventListener('click', () => {
				mobileMenu.classList.add('hidden');
			});
		});
	}
</script>
