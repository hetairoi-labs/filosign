{
	"compilerOptions": {
		"jsx": "react-jsx",
		"allowJs": true,
		"strictNullChecks": true,
		"strict": true,
		"moduleResolution": "bundler",
		"module": "Preserve",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"paths": {
			"@/*": ["./*"]
		},
		"target": "ESNext",
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"types": ["vite/client"]
	},
	"include": ["**/*.ts", "**/*.tsx"],
	"exclude": ["dist", "node_modules"]
}
