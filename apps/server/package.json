{
	"name": "@filosign/server",
	"scripts": {
		"dev:local": "bun run --env-file=.env.local --hot index.ts",
		"dev:testnet": "bun run --env-file=.env.staging --hot index.ts",
		"db:purge:local": "bun run --env-file=.env.local scripts/clear-db.ts",
		"db:purge:testnet": "bun run --env-file=.env.staging scripts/clear-db.ts",
		"drizzle-kit:push": "bunx --bun drizzle-kit push",
		"db:push:local": "bun run --env-file=.env.local drizzle-kit:push",
		"db:push:testnet": "bun run --env-file=.env.staging drizzle-kit:push",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./index.ts --outfile out/server",
		"check": "bunx --bun biome check --write",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@filosign/contracts": "workspace:*",
		"@filosign/crypto-utils": "workspace:*",
		"@filosign/shared": "workspace:*",
		"@filoz/synapse-sdk": "^0.40.3",
		"@hono/zod-validator": "catalog:",
		"@libsql/client": "0.14.0",
		"@privy-io/node": "0.18.0",
		"dotenv": "17.4.2",
		"drizzle-orm": "0.44.7",
		"drizzle-zod": "0.8.3",
		"ethers": "catalog:",
		"fast-json-stable-stringify": "catalog:",
		"hono": "catalog:",
		"jsonwebtoken": "9.0.2",
		"pg": "8.16.3",
		"resend": "6.4.0",
		"viem": "catalog:",
		"wagmi": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@t3-oss/env-core": "catalog:",
		"@types/bun": "catalog:",
		"@types/jsonwebtoken": "9.0.10",
		"@types/node": "catalog:",
		"@types/pg": "8.15.6",
		"drizzle-kit": "0.31.6"
	}
}