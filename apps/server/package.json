{
	"name": "@filosign/server",
	"scripts": {
		"check": "bunx --bun biome check --write",
		"dev": "bun --hot index.ts",
		"start": "bun run index.ts",
		"push": "bunx --bun drizzle-kit push",
		"tsc": "tsc --noEmit",
		"db:purge": "bun run scripts/clear-db.ts",
		"db:push": "bunx --bun drizzle-kit push",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./index.ts --outfile out/server"
	},
	"dependencies": {
		"@filosign/contracts": "workspace:*",
		"@filosign/crypto-utils": "workspace:*",
		"@filosign/shared": "workspace:*",
		"@filoz/synapse-sdk": "^0.40.3",
		"@hono/zod-validator": "catalog:",
		"@libsql/client": "0.14.0",
		"drizzle-orm": "0.44.7",
		"drizzle-zod": "0.8.3",
		"ethers": "catalog:",
		"fast-json-stable-stringify": "catalog:",
		"hono": "catalog:",
		"jsonwebtoken": "9.0.2",
		"pg": "8.16.3",
		"resend": "6.4.0",
		"viem": "catalog:",
		"wagmi": "catalog:",
		"zod": "catalog:",
		"dotenv": "17.4.2"
	},
	"devDependencies": {
		"@t3-oss/env-core": "catalog:",
		"@types/bun": "catalog:",
		"@types/jsonwebtoken": "9.0.10",
		"@types/node": "catalog:",
		"@types/pg": "8.15.6",
		"drizzle-kit": "0.31.6"
	}
}
