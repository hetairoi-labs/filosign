{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./*"]
		},
		"types": ["bun"]
	},
	"include": ["./**/*.ts"],
	"exclude": ["./**/*.test.ts", "./**/*.spec.ts", "./**/test.ts", "./scripts/*"]
}
