{
	"name": "@filosign/server",
	"scripts": {
		"check": "bunx --bun biome check --write",
		"dev": "bun --hot index.ts",
		"start": "bun run index.ts",
		"push": "bunx --bun drizzle-kit push",
		"tsc": "tsc --noEmit",
		"db:purge": "bun run scripts/clear-db.ts",
		"db:push": "bunx --bun drizzle-kit push",
		"compile": "bun build --compile --minify --sourcemap --bytecode ./index.ts --outfile out/server"
	},
	"dependencies": {
		"@filosign/contracts": "workspace:*",
		"@filosign/crypto-utils": "workspace:*",
		"@filosign/shared": "workspace:*",
		"@filoz/synapse-sdk": "^0.40.3",
		"@hono/zod-validator": "^0.7.3",
		"@libsql/client": "^0.14.0",
		"@worldcoin/idkit": "4.0.11",
		"drizzle-orm": "0.44.7",
		"drizzle-zod": "^0.8.3",
		"ethers": "^6.15.0",
		"fast-json-stable-stringify": "^2.1.0",
		"hono": "^4.9.8",
		"jsonwebtoken": "^9.0.2",
		"pg": "8.16.3",
		"resend": "6.4.0",
		"viem": "2.38.3",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@types/bun": "1.3.1",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "24.9.1",
		"@types/pg": "8.15.6",
		"drizzle-kit": "0.31.6"
	}
}
