{
	"name": "@filosign/crypto-utils",
	"version": "0.1.0",
	"description": "Crypto utilities for FiloSign",
	"exports": {
		".": {
			"default": "./src/lib-web.ts"
		},
		"./node": {
			"default": "./src/lib-node.ts"
		},
		"./dilithium.wasm": "./assets/dilithium.wasm",
		"./browser/dilithium": {
			"default": "./src/browser/load-dilithium.ts"
		}
	},
	"scripts": {
		"check-types": "tsc --noEmit -p tsconfig.json",
		"test": "bun test lib.test.ts",
		"sync:wasm": "bun run scripts/sync-dilithium-wasm.ts",
		"prepare": "bun run sync:wasm"
	},
	"devDependencies": {
		"typescript": "catalog:",
		"@types/argon2": "^0.15.4",
		"@types/argon2-browser": "^1.18.4",
		"@types/bun": "catalog:",
		"@types/node": "catalog:"
	},
	"dependencies": {
		"@wordlist/english-eff": "^1.0.1",
		"argon2": "^0.44.0",
		"argon2-browser": "catalog:",
		"crystals-kyber-js": "2.5.0",
		"dilithium-crystals-js": "catalog:",
		"fast-json-stable-stringify": "catalog:",
		"mlkem": "catalog:"
	},
	"peerDependencies": {
		"viem": "catalog:"
	}
}
