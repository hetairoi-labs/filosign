{
	"name": "filosign",
	"version": "1.0.0",
	"description": "Private Document Signing",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "bun run scripts/dev.ts",
		"dev:local": "bun run dev -- --local",
		"dev:local:full": "bun run dev -- --local --full",
		"dev:testnet": "bun run dev -- --testnet",
		"db": "bun run scripts/db.ts",
		"serloc": "./scripts/serloc.sh",
		"contracts:migrate": "./scripts/migrate.sh",
		"contracts:migrate:testnet": "./scripts/migrate.sh testnet",
		"contracts:migrate:mainnet": "./scripts/migrate.sh mainnet",
		"test:dev": "bun run --cwd packages/test dev",
		"check": "biome check --write .",
		"check:ci": "biome check .",
		"check-types": "turbo run check-types --filter=@filosign/*",
		"test": "turbo run test --filter=@filosign/* --filter=!@filosign/contracts",
		"build": "turbo run build --filter=@filosign/*",
		"purge:modules": "./scripts/purge.sh",
		"sanity:check": "bun run check:ci && bun run check-types && bun run test",
		"sanity:check:full": "bun run sanity:check && bun run --cwd apps/contracts test",
		"sanity:fix": "bun run check && bun run check-types && bun run test",
		"prepare": "husky"
	},
	"engines": {
		"bun": ">=1.3.13",
		"node": ">=25"
	},
	"packageManager": "bun@1.0.0",
	"catalog": {
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"@types/react": "^19.1.16",
		"@types/react-dom": "^19.1.9",
		"typescript": "6.0.3",
		"@types/node": "25.6.2",
		"@types/bun": "1.3.13",
		"viem": "2.48.11",
		"wagmi": "2.19.1",
		"ethers": "6.15.0",
		"@tanstack/react-query": "5.90.6",
		"zod": "4.3.6",
		"hono": "^4.9.8",
		"@hono/zod-validator": "0.7.6",
		"axios": "^1.12.2",
		"dilithium-crystals-js": "1.1.3",
		"argon2-browser": "^1.18.0",
		"multiformats": "13.4.1",
		"idb": "8.0.3",
		"browser-image-compression": "2.0.2",
		"mlkem": "2.5.0",
		"@web3-storage/data-segment": "5.3.0",
		"fast-json-stable-stringify": "2.1.0",
		"@biomejs/biome": "2.4.14",
		"prettier": "3.8.3",
		"@t3-oss/env-core": "0.13.11",
		"tailwindcss": "4.1.16",
		"@tailwindcss/vite": "4.2.4",
		"tailwind-merge": "3.3.1",
		"vite": "8.0.11",
		"@vitejs/plugin-react": "6.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@types/bun": "catalog:",
		"@types/node": "catalog:",
		"husky": "9.1.7",
		"prettier": "catalog:",
		"turbo": "^2.5.4",
		"typescript": "catalog:"
	},
	"overrides": {
		"@tanstack/react-query": "catalog:",
		"viem": "catalog:"
	},
	"patchedDependencies": {
		"dilithium-crystals-js@1.1.3": "patches/dilithium-crystals-js@1.1.3.patch"
	},
	"dependencies": {
		"zod": "4.4.3"
	}
}
