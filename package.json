{
	"name": "filosign",
	"version": "1.0.0",
	"description": "Filosign monorepo",
	"private": true,
	"workspaces": [
		"test",
		"packages/client",
		"packages/server",
		"packages/contracts",
		"packages/lib/react-sdk",
		"packages/lib/crypto-utils",
		"packages/lib/shared"
	],
	"scripts": {
		"web:dev": "bun run --parallel client:dev server:dev",
		"client:dev": "bun run --cwd packages/client dev",
		"client:build": "bun run --cwd packages/client build",
		"client:start": "bun run --cwd packages/client start",
		"client:test": "bun run --cwd test dev",
		"server:dev": "bun run --cwd packages/server dev",
		"server:start": "bun run --cwd packages/server start",
		"server:compile": "bun run --cwd packages/server compile",
		"db:push": "bun run --cwd packages/server db:push",
		"migrate": "bun run --cwd packages/contracts migrate",
		"migrate:testnet": "bun run --cwd packages/contracts migrate:testnet",
		"check": "bunx biome check --write"
	},
	"engines": {
		"bun": ">=1.3.11",
		"node": ">=24"
	},
	"packageManager": "bun@1.0.0",
	"devDependencies": {
		"@biomejs/biome": "2.3.14",
		"@types/sharp": "0.32.0",
		"husky": "9.1.7",
		"prettier": "3.8.1",
		"sharp": "0.34.5",
		"typescript": "5.9.3"
	},
	"dependencies": {
		"@hono/zod-validator": "0.7.6",
		"@privy-io/wagmi": "2.0.2",
		"dotenv": "17.2.4",
		"ipaddr.js": "2.2.0",
		"viem": "2.38.5"
	},
	"overrides": {
		"@tanstack/react-query": "^5.90.2"
	},
	"patchedDependencies": {
		"dilithium-crystals-js@1.1.3": "patches/dilithium-crystals-js@1.1.3.patch"
	}
}
