{
	"name": "filosign",
	"version": "1.0.0",
	"description": "Private Document Signing",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"web:dev:local": "bun run --parallel serloc client:dev:local astro:dev",
		"web:dev:testnet": "bun run --parallel client:dev:testnet server:dev:testnet",
		"client:dev:local": "bun run --cwd apps/client dev:local",
		"client:dev:testnet": "bun run --cwd apps/client dev:testnet",
		"client:build": "bun run --cwd apps/client build",
		"astro:dev": "bun run --cwd apps/astro dev",
		"astro:build": "bun run --cwd apps/astro build",
		"server:dev:local": "bun run --cwd apps/server dev:local",
		"server:dev:testnet": "bun run --cwd apps/server dev:testnet",
		"server:compile": "bun run --cwd apps/server compile",
		"server:start": "bun run --cwd apps/server start",
		"contracts:test": "bun run --cwd apps/contracts test",
		"contracts:migrate": "./scripts/migrate.sh",
		"test:dev": "bun run --cwd packages/test dev",
		"check": "bunx biome check --write",
		"check-types": "bun -F @filosign/server check-types && bun -F @filosign/client check-types",
		"client:typecheck": "bunx tsc -p apps/client/tsconfig.json --noEmit",
		"client:verify": "bun run client:typecheck && bun run client:build && bun run --cwd apps/client lint",
		"serloc": "./scripts/serloc.sh",
		"db:purge:local": "bun run --cwd apps/server db:purge:local",
		"db:purge:testnet": "bun run --cwd apps/server db:purge:testnet",
		"db:push:local": "bun run --cwd apps/server db:push:local",
		"db:push:testnet": "bun run --cwd apps/server db:push:testnet",
		"purge:modules": "./scripts/purge.sh",
		"test": "bun run --cwd packages/shared test && bun run --cwd apps/server test && bun run --cwd apps/client test"
	},
	"engines": {
		"bun": ">=1.3.12",
		"node": ">=24"
	},
	"packageManager": "bun@1.0.0",
	"catalog": {
		"react": "^19.1.1",
		"react-dom": "^19.1.1",
		"@types/react": "^19.1.16",
		"@types/react-dom": "^19.1.9",
		"typescript": "6.0.3",
		"@types/node": "25.6.2",
		"@types/bun": "1.3.13",
		"viem": "2.48.11",
		"wagmi": "2.19.1",
		"ethers": "6.15.0",
		"@tanstack/react-query": "5.90.6",
		"zod": "4.3.6",
		"hono": "^4.9.8",
		"@hono/zod-validator": "0.7.6",
		"axios": "^1.12.2",
		"dilithium-crystals-js": "1.1.3",
		"argon2-browser": "^1.18.0",
		"multiformats": "13.4.1",
		"idb": "8.0.3",
		"browser-image-compression": "2.0.2",
		"mlkem": "2.5.0",
		"@web3-storage/data-segment": "5.3.0",
		"fast-json-stable-stringify": "2.1.0",
		"@biomejs/biome": "2.4.14",
		"prettier": "3.8.3",
		"@t3-oss/env-core": "0.13.11",
		"tailwindcss": "4.1.16",
		"@tailwindcss/vite": "4.2.4",
		"tailwind-merge": "3.3.1",
		"vite": "8.0.11",
		"@vitejs/plugin-react": "6.0.1"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.14",
		"@types/bun": "catalog:",
		"@types/node": "catalog:",
		"husky": "9.1.7",
		"prettier": "catalog:",
		"typescript": "catalog:"
	},
	"overrides": {
		"@tanstack/react-query": "catalog:",
		"viem": "catalog:"
	},
	"patchedDependencies": {
		"dilithium-crystals-js@1.1.3": "patches/dilithium-crystals-js@1.1.3.patch"
	},
	"dependencies": {
		"zod": "4.4.3"
	}
}
