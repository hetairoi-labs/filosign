{
	"name": "filosign",
	"version": "1.0.0",
	"description": "Private Document Signing",
	"private": true,
	"workspaces": [
		"test",
		"apps/client",
		"apps/server",
		"apps/contracts",
		"packages/react-sdk",
		"packages/crypto-utils",
		"packages/shared"
	],
	"scripts": {
		"web:dev": "bun run --parallel client:dev server:dev",
		"client:dev": "bun run --cwd apps/client dev",
		"client:build": "bun run --cwd apps/client build",
		"client:start": "bun run --cwd apps/client start",
		"server:dev": "bun run --cwd apps/server dev",
		"server:start": "bun run --cwd apps/server start",
		"server:compile": "bun run --cwd apps/server compile",
		"test:dev": "bun run --cwd test dev",
		"check": "bunx biome check --write",
		"check:ci": "bunx biome check .",
		"client:typecheck": "bunx tsc -p apps/client/tsconfig.json --noEmit",
		"client:verify": "bun run client:typecheck && bun run client:build && bun run --cwd apps/client lint",
		"serloc": "./scripts/serloc.sh",
		"db:purge": "bun run --cwd apps/server db:purge",
		"db:push": "bun run --cwd apps/server db:push",
		"migrate": "./scripts/migrate.sh",
		"purge:modules": "./scripts/purge.sh"
	},
	"engines": {
		"bun": ">=1.3.12",
		"node": ">=24"
	},
	"packageManager": "bun@1.0.0",
	"devDependencies": {
		"@biomejs/biome": "2.3.14",
		"@types/sharp": "0.32.0",
		"husky": "9.1.7",
		"prettier": "3.8.1",
		"sharp": "0.34.5",
		"typescript": "5.9.3"
	},
	"dependencies": {
		"@hono/zod-validator": "0.7.6",
		"@privy-io/wagmi": "2.0.2",
		"dotenv": "17.2.4",
		"ipaddr.js": "2.2.0",
		"viem": "2.48.4"
	},
	"overrides": {
		"@tanstack/react-query": "^5.90.2",
		"viem": "2.48.4"
	},
	"patchedDependencies": {
		"dilithium-crystals-js@1.1.3": "patches/dilithium-crystals-js@1.1.3.patch"
	}
}
